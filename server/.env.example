# # TENANCY Backend Configuration
# # Copy to .env before running

# # Server Configuration
# PORT=4010
# NODE_ENV=development

# # API Security - change this to a strong API key
# API_KEY=tenancy_dev_key_2024

# # Chainlink Price Feed Configuration
# # Sepolia ETH/USD Price Feed
# CHAINLINK_ETH_USD_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306

# # Base ETH/USD Price Feed (optional)
# # CHAINLINK_ETH_USD_FEED=0x71041dddad35a2F9D388c02D0DBE565255403061

# # Ethereum RPC URL (Sepolia testnet)
# RPC_URL=https://rpc.sepolia.org

# # Use Real Chainlink Price Feeds
# # Set to 'true' to fetch real prices from Chainlink
# # Set to 'false' to use fallback mock prices
# USE_REAL_PRICES=false

# # Backend URL for frontend
# BACKEND_URL=http://localhost:4010
