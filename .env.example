# =============================================================================
# TENANCY Protocol - Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your real values.
# See deployment guide for each section below.
# NEVER commit .env files with real private keys or API secrets to git.
# =============================================================================

# =============================================================================
# PART 1: FRONTEND  (Vite / React — prefix VITE_ required)
# =============================================================================

# Authentication — get App ID from https://dashboard.privy.io
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Network
VITE_NETWORK=base_sepolia
VITE_DEFAULT_CHAIN_ID=84532

# RPC URLs — get API key from https://alchemy.com
VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Contract Addresses: Base Sepolia (current active deployment)
VITE_PROPERTY_REGISTRY_BASE_SEPOLIA=0x6d51cE756C9622A3399CBb7355321d4A326Ec09d
VITE_TEN_TOKEN_BASE_SEPOLIA=0x214E4a7f581c3f09F6eAE495C5B32836996a41c6
VITE_YIELD_DISTRIBUTOR_BASE_SEPOLIA=0xBd9003d875267E7694B500091590C6eC2ddb5510
VITE_PRICE_FEED_CONSUMER_BASE_SEPOLIA=0xdcd90ADe757a020B7bA917F0f943a01e3b042091
VITE_MARKETPLACE_BASE_SEPOLIA=0x1A7d33B33AeCFc22590ae3150D40C5A0F8e63048
VITE_RENTAL_TOKEN_BASE_SEPOLIA=0xa5703d8408874f49d64398E1b355b8381894e277

# Payment Token: USDC on Base Sepolia (Circle official)
VITE_PAYMENT_TOKEN_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Contract Addresses: Ethereum Sepolia (legacy / reference only)
VITE_PROPERTY_REGISTRY_SEPOLIA=0x452ba94272f3302E7b48bFFC1F5a57ec7136A6aA
VITE_TEN_TOKEN_SEPOLIA=0x9e395acF058c74386b531e4c901C53B1c73E6D5F
VITE_YIELD_DISTRIBUTOR_SEPOLIA=0x84bc076C939Aa2B70e0DaEbA708B3aDa3881a179
VITE_PRICE_FEED_CONSUMER_SEPOLIA=0xE88A399F85550dDF61f9DD6Cb91e2673817D7f91
VITE_MARKETPLACE_SEPOLIA=0xE07db63A23d6572dB1374B49DB7Cc063BE0aE035

# Chainlink
CHAINLINK_ETH_USD_SEPOLIA=0x694AA1769357215DE4FAC081bf1f309aDC325306
CHAINLINK_ETH_USD_BASE_SEPOLIA=0x4a5816300e0eE47A41DFcDB12A8C8bB6dD18C12
VITE_CHAINLINK_ROUTER=0xf9B8fc078197181C841c296C876945aaa425B278
VITE_CHAINLINK_SUBSCRIPTION_ID=your_subscription_id

# IPFS / Pinata — get from https://pinata.cloud
VITE_PINATA_JWT=your_pinata_jwt_here
IPFS_API_KEY=your_pinata_api_key
IPFS_API_SECRET=your_pinata_api_secret

# Backend API
VITE_BACKEND_URL=http://localhost:4010
VITE_API_KEY=your_api_key_here

# MoonPay — get test keys from https://dashboard.moonpay.com (Test mode)
VITE_FEATURE_MOONPAY=true
VITE_MOONPAY_PUBLISHABLE_KEY=pk_test_your_moonpay_publishable_key
MOONPAY_SECRET_KEY=sk_test_your_moonpay_secret_key
MOONPAY_WEBHOOK_KEY=wk_test_your_moonpay_webhook_key

# Frontend URL
VITE_FRONTEND_URL=http://localhost:5175

# Feature flags
VITE_ALLOW_MOCK_IPFS=false
VITE_DEMO_MODE=false


# =============================================================================
# PART 2: SMART CONTRACTS  (Foundry — place in contracts/.env)
# =============================================================================

# Deployer private key — NEVER use a funded key in version control
# PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# RPC endpoint for deployment
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Basescan API key for contract verification (optional)
# BASESCAN_API_KEY=your_basescan_api_key


# =============================================================================
# PART 3: BACKEND SERVER  (Node.js Express — place in server/.env)
# =============================================================================

PORT=4010
NODE_ENV=development

# PostgreSQL — Aiven or any Postgres provider
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# API key for protected endpoints (keep in sync with VITE_API_KEY)
API_KEY=your_api_key_here

# Chainlink ETH/USD Price Feed on Base Sepolia
CHAINLINK_ETH_USD_FEED=0x71041dddad35a2F9D388c02D0DBE565255403061

# RPC URL (Base Sepolia)
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Set to 'true' to fetch real Chainlink prices; 'false' to use mock fallback
USE_REAL_PRICES=true

# Contract addresses (Base Sepolia — must match VITE_ vars above)
PROPERTY_REGISTRY_ADDRESS=0x6d51cE756C9622A3399CBb7355321d4A326Ec09d
YIELD_DISTRIBUTOR_ADDRESS=0xBd9003d875267E7694B500091590C6eC2ddb5510
TEN_TOKEN_ADDRESS=0x214E4a7f581c3f09F6eAE495C5B32836996a41c6
MARKETPLACE_ADDRESS=0x1A7d33B33AeCFc22590ae3150D40C5A0F8e63048
PRICE_FEED_CONSUMER_ADDRESS=0xdcd90ADe757a020B7bA917F0f943a01e3b042091

# MoonPay webhooks
MOONPAY_SECRET_KEY=sk_test_your_moonpay_secret_key
MOONPAY_WEBHOOK_KEY=wk_test_your_moonpay_webhook_key

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5175


# =============================================================================
# PART 4: CRE WORKFLOW  (Chainlink CRE SDK — place in cre-workflow/.env)
# Deployed via: cd cre-workflow && npm run deploy
# Simulated via: cd cre-workflow && npm run simulate
# =============================================================================

# LLM provider (choose openai, groq, or ollama)
OPENAI_API_KEY=sk-your-openai-api-key
# GROQ_API_KEY=your_groq_api_key

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Alchemy key for project.yaml production RPC (used as ${BASE_SEPOLIA_ALCHEMY_KEY})
BASE_SEPOLIA_ALCHEMY_KEY=YOUR_ALCHEMY_KEY

# CRE deployer private key — must have Base Sepolia ETH for gas
# NEVER use Hardhat default key (0xac097...) in production
CRE_ETH_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Payment API key (same as API_KEY in server/.env)
PAYMENT_API_KEY=your_api_key_here

# MoonPay (optional, only if workflow needs it)
MOONPAY_PUBLISHABLE_KEY=pk_test_your_moonpay_publishable_key
MOONPAY_SECRET_KEY=sk_test_your_moonpay_secret_key
